generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id            String    @id @default(cuid())
  email         String    @unique
  nombre        String
  claveHash     String
  plan          String    @default("TRIAL") // TRIAL | STARTER | PROFESIONAL | BUSINESS | ENTERPRISE
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  // Flow.cl billing
  flowCustomerId      String?
  flowSubscriptionId  String?
  planVencimiento     DateTime?
  trialUsado          Boolean   @default(false)
  trialInicio         DateTime?

  empresas  Empresa[]

  @@map("clientes")
}

model Empresa {
  id            String    @id @default(cuid())
  nombre        String
  rut           String
  siiRut        String
  siiClaveEnc   String
  apiToken      String    @unique @default(uuid())
  activa        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  clienteId  String
  cliente    Cliente    @relation(fields: [clienteId], references: [id])

  webhookUrl    String?
  webhookSecret String?

  extracciones  Extraccion[]
  logsUso       LogUso[]
  ventas        Venta[]
  compras       Compra[]
  honorarios    Honorario[]
  f29s          F29Genapi[]

  @@map("empresas")
}

model Extraccion {
  id            String   @id @default(uuid())
  period        String
  modulo        String   // ventas | compras | f29 | honorarios
  estado        String   @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  filas         Int?
  errorMsg      String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  ventas     Venta[]
  compras    Compra[]
  honorarios Honorario[]
  f29        F29Genapi?

  @@map("extracciones")
}

model Venta {
  id             Int      @id @default(autoincrement())
  period         String
  docType        String
  docNumber      String
  rutEmisor      String
  nombreEmisor   String
  rutReceptor    String
  nombreReceptor String
  fechaEmision   String
  montoNeto      Int      @default(0)
  montoIva       Int      @default(0)
  montoTotal     Int      @default(0)
  montoExento    Int      @default(0)
  extractedAt    DateTime @default(now())

  empresaId    String
  extraccionId String
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  extraccion   Extraccion @relation(fields: [extraccionId], references: [id])

  @@map("ventas")
}

model Compra {
  id             Int      @id @default(autoincrement())
  period         String
  docType        String
  docNumber      String
  rutEmisor      String
  nombreEmisor   String
  rutReceptor    String
  nombreReceptor String
  fechaEmision   String
  montoNeto      Int      @default(0)
  montoIva       Int      @default(0)
  montoTotal     Int      @default(0)
  montoExento    Int      @default(0)
  extractedAt    DateTime @default(now())

  empresaId    String
  extraccionId String
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  extraccion   Extraccion @relation(fields: [extraccionId], references: [id])

  @@map("compras")
}

model LogUso {
  id        String   @id @default(cuid())
  endpoint  String
  period    String?
  ip        String?
  creadoEn  DateTime @default(now())

  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])

  @@map("logs_uso")
}

model Honorario {
  id             String   @id @default(uuid())
  anio           String
  mes            String
  folio          String
  fechaEmision   String
  rutEmisor      String
  nombreEmisor   String
  montoBruto     Int      @default(0)
  retencion      Int      @default(0)
  montoLiquido   Int      @default(0)
  extractedAt    DateTime @default(now())

  empresaId    String
  extraccionId String
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  extraccion   Extraccion @relation(fields: [extraccionId], references: [id])

  @@map("honorarios")
}

model F29Genapi {
  id                  String   @id @default(uuid())
  period              String
  ivaDebito           Int      @default(0)
  ivaCredito          Int      @default(0)
  ivaRemanente        Int      @default(0)
  ivaNeto             Int      @default(0)
  retencionHonorarios Int      @default(0)
  ppm                 Int      @default(0)
  totalPagar          Int      @default(0)
  rawData             Json?
  extractedAt         DateTime @default(now())

  empresaId    String
  extraccionId String   @unique
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  extraccion   Extraccion @relation(fields: [extraccionId], references: [id])

  @@map("f29_genapi")
}

model IndicadorEconomico {
  id      String @id @default(uuid())
  periodo String
  nombre  String
  valor   Float
  fecha   String

  @@unique([periodo, nombre])
  @@map("indicadores_economicos")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  claveHash String
  creadoEn  DateTime @default(now())

  @@map("admins")
}
