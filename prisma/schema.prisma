generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id            String    @id @default(cuid())
  email         String    @unique
  nombre        String
  claveHash     String
  plan          String    @default("STARTER") // STARTER | PROFESIONAL | BUSINESS | ENTERPRISE
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  empresas  Empresa[]

  @@map("clientes")
}

model Empresa {
  id            String    @id @default(cuid())
  nombre        String
  rut           String
  siiRut        String
  siiClaveEnc   String
  apiToken      String    @unique @default(uuid())
  activa        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  clienteId  String
  cliente    Cliente    @relation(fields: [clienteId], references: [id])

  extracciones  Extraccion[]
  logsUso       LogUso[]
  ventas        Venta[]
  compras       Compra[]

  @@map("empresas")
}

model Extraccion {
  id            String   @id @default(uuid())
  period        String
  modulo        String   // ventas | compras | f29 | honorarios
  estado        String   @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  filas         Int?
  errorMsg      String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  ventas     Venta[]
  compras    Compra[]

  @@map("extracciones")
}

model Venta {
  id             Int      @id @default(autoincrement())
  period         String
  docType        String
  docNumber      String
  rutEmisor      String
  nombreEmisor   String
  rutReceptor    String
  nombreReceptor String
  fechaEmision   String
  montoNeto      Int      @default(0)
  montoIva       Int      @default(0)
  montoTotal     Int      @default(0)
  montoExento    Int      @default(0)
  extractedAt    DateTime @default(now())

  empresaId    String
  extraccionId String
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  extraccion   Extraccion @relation(fields: [extraccionId], references: [id])

  @@map("ventas")
}

model Compra {
  id             Int      @id @default(autoincrement())
  period         String
  docType        String
  docNumber      String
  rutEmisor      String
  nombreEmisor   String
  rutReceptor    String
  nombreReceptor String
  fechaEmision   String
  montoNeto      Int      @default(0)
  montoIva       Int      @default(0)
  montoTotal     Int      @default(0)
  montoExento    Int      @default(0)
  extractedAt    DateTime @default(now())

  empresaId    String
  extraccionId String
  empresa      Empresa    @relation(fields: [empresaId], references: [id])
  extraccion   Extraccion @relation(fields: [extraccionId], references: [id])

  @@map("compras")
}

model LogUso {
  id        String   @id @default(cuid())
  endpoint  String
  period    String?
  ip        String?
  creadoEn  DateTime @default(now())

  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id])

  @@map("logs_uso")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  claveHash String
  creadoEn  DateTime @default(now())

  @@map("admins")
}
